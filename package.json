{
	"name": "rezervo-alpine",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.7.0",
	"scripts": {
		"dev": "vite",
		"dev:auth": "cargo run --manifest-path auth-proxy/Cargo.toml",
		"build": "vite build",
		"preview": "vite preview",
		"typecheck": "tsc --noEmit",
		"format": "biome format --write .",
		"check": "biome ci"
	},
	"dependencies": {
		"alpinejs": "^3.14.1",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.8",
		"@types/alpinejs": "^3.13.10",
		"@types/node": "^25.5.0",
		"typescript": "^5.4.5",
		"vite": "^5.2.12"
	}
}
